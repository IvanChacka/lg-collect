# 法律热点采集系统配置
# 从原始 .env 复制，修改为法律热点搜索

# =================
# 运行时核心配置
# =================
CHECKPOINT_SQLITE_PATH=.data/checkpoints.sqlite
THREAD_ID=

# =================
# 大模型（LLM）
# =================
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.2
LLM_MAX_TOKENS=
DEEPSEEK_TIMEOUT_SECONDS=300
LLM_DEBUG=1
LLM_DEBUG_LOG_PATH=.data/llm_debug.log

# =================
# 热点源（法律相关）
# =================
HOT_SOURCE=official
WEIBO_HOT_SOURCE=tophub_html
DOUYIN_HOT_SOURCE=official

SEARCH_PROVIDER=bing_web
SEARCH_FETCH_MODE=http
SEARCH_TIMEOUT_SECONDS=30

ARTICLES_PER_KEYWORD=
ARTICLE_LLM_KEEP_LIMIT=3
SELECTED_ARTICLE_QUERIES_LIMIT=3

VIDEO_PROVIDER=
VIDEOS_PER_KEYWORD=
VIDEO_LLM_KEEP_LIMIT=3
SELECTED_VIDEO_QUERIES_LIMIT=3

# =================
# 爬虫基础设施
# =================
CRAWL_PROXY=
CRAWL_CACHE_SQLITE=.data/crawl_cache.sqlite
PAGE_CACHE_TTL_SECONDS=3600

# =================
# 飞书（可选 - 如不需要人工交互可跳过）
# =================
FEISHU_WEBHOOK_URL=

# =================
# LangSmith（可选）
# =================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=hot-collect-law

# =================
# 搜索重试
# =================
SEARCH_MAX_ATTEMPTS=3
SEARCH_RETRY_BACKOFF_SECONDS=2
SEARCH_DEBUG_DUMP=1
SEARCH_DEBUG_DUMP_MODE=always

BG_JOB_ISOLATED_LOOPS=true
